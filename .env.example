# ============================================================
# APP COBRANÇAS WEB — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# ============================================================

# --- Banco de Dados (PostgreSQL) ---
# Supabase:  postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres
# Railway:   postgresql://postgres:[SENHA]@[HOST]:5432/railway
DATABASE_URL="postgresql://user:password@localhost:5432/cobrancas"

# --- NextAuth ---
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-minimo-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# --- JWT para Mobile ---
# Mesmo secret usado para validar tokens do app mobile
JWT_SECRET="sua-chave-jwt-minimo-32-chars"
JWT_EXPIRES_IN="30d"

# --- App ---
NEXT_PUBLIC_APP_NAME="App Cobranças"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin padrão (apenas para seed inicial) ---
ADMIN_EMAIL="admin@locacao.com"
ADMIN_SENHA="admin123"
ADMIN_NOME="Administrador"
