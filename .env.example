# ============================================================================
# ⚠️ NUNCA use estes valores em produção!
# Este arquivo é apenas um modelo. Copie para .env e substitua TODOS os
# valores por credenciais reais e seguras antes de implantar.
# ============================================================================

# ----------------------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# ----------------------------------------------------------------------------
# Connection string do PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/database
DATABASE_URL="postgresql://postgres:SUA_SENHA_SEGURA_AQUI@localhost:5432/cobrancas"

# ----------------------------------------------------------------------------
# AUTENTICAÇÃO
# ----------------------------------------------------------------------------
# Chave secreta para assinar JWTs do NextAuth (mínimo 32 caracteres)
# GERE_COM: openssl rand -base64 32
NEXTAUTH_SECRET="GERE_COM: openssl rand -base64 32"

# URL pública da aplicação (usada pelo NextAuth)
NEXTAUTH_URL="http://localhost:3000"

# Chave secreta separada para JWTs do mobile (opcional — usa NEXTAUTH_SECRET se não definido)
# Recomendado: usar chave diferente do NextAuth para isolamento de segurança
# GERE_COM: openssl rand -base64 32
JWT_SECRET="GERE_COM: openssl rand -base64 32"

# Tempo de expiração do token JWT do mobile (padrão: 15 minutos)
# O mobile deve usar /api/mobile/auth/refresh para renovar
JWT_EXPIRES_IN="15m"

# Tempo máximo da sessão NextAuth (web) em segundos (padrão: 30 dias)
# NEXTAUTH_SESSION_MAX_AGE="2592000"

# ----------------------------------------------------------------------------
# ADMIN INICIAL (usado no endpoint /api/admin/init)
# ----------------------------------------------------------------------------
# Email do administrador padrão
INIT_ADMIN_EMAIL="seu-email-admin@exemplo.com"

# Senha do administrador padrão (obrigatório no init)
INIT_ADMIN_PASSWORD="SUA_SENHA_SEGURA_AQUI"

# Chave secreta para autorizar o endpoint de inicialização (obrigatório)
# GERE_COM: openssl rand -base64 32
INIT_SECRET="GERE_COM: openssl rand -base64 32"

# ----------------------------------------------------------------------------
# MIGRAÇÕES
# ----------------------------------------------------------------------------
# Token para autorizar migrações manuais via /api/admin/migrate (obrigatório)
# NÃO usar fallback — se não configurado, o endpoint recusa
# GERE_COM: openssl rand -base64 32
MIGRATION_TOKEN="GERE_COM: openssl rand -base64 32"

# Permitir endpoint de init em produção (padrão: false)
ALLOW_INIT_ENDPOINT="false"

# ----------------------------------------------------------------------------
# SINCRONIZAÇÃO
# ----------------------------------------------------------------------------
# Estratégia padrão para conflitos: newest | remote | local | manual
SYNC_CONFLICT_STRATEGY="newest"

# Limite de dias sem sync para considerar device estale (padrão: 30)
SYNC_STALE_THRESHOLD_DAYS="30"

# Rounds do bcrypt para hash de senha (recomendado: 12)
BCRYPT_ROUNDS="12"

# ----------------------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------------------
# Nível de log: debug | info | warn | error (produção usa 'warn' por padrão)
LOG_LEVEL="debug"

# ----------------------------------------------------------------------------
# AMBIENTE
# ----------------------------------------------------------------------------
# Ambiente: development | production | test
NODE_ENV="development"
