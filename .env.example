# ============================================================================
# CONFIGURAÇÕES DE AMBIENTE - APP COBRANÇAS WEB
# Copie este arquivo para .env e ajuste os valores conforme seu ambiente
# ============================================================================

# ----------------------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# ----------------------------------------------------------------------------
# Connection string do PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/database
DATABASE_URL="postgresql://postgres:password@localhost:5432/cobrancas"

# ----------------------------------------------------------------------------
# AUTENTICAÇÃO
# ----------------------------------------------------------------------------
# Chave secreta para assinar JWTs (mínimo 32 caracteres)
# Gere uma nova com: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-minimo-32-caracteres"

# URL pública da aplicação (usada pelo NextAuth)
NEXTAUTH_URL="http://localhost:3000"

# Tempo de expiração do token JWT (padrão: 30 dias)
JWT_EXPIRES_IN="30d"

# ----------------------------------------------------------------------------
# ADMIN INICIAL (usado no seed)
# ----------------------------------------------------------------------------
# Email do administrador padrão
ADMIN_EMAIL="admin@locacao.com"

# Senha do administrador padrão
ADMIN_SENHA="admin123"

# Nome do administrador
ADMIN_NOME="Administrador"

# ----------------------------------------------------------------------------
# SINCRONIZAÇÃO
# ----------------------------------------------------------------------------
# Estratégia padrão para conflitos: newest | remote | local | manual
SYNC_CONFLICT_STRATEGY="newest"

# Rounds do bcrypt para hash de senha (recomendado: 12)
BCRYPT_ROUNDS="12"

# ----------------------------------------------------------------------------
# AMBIENTE
# ----------------------------------------------------------------------------
# Ambiente: development | production | test
NODE_ENV="development"
